rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user document
    match /users/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Users can read, write, update and delete their own earnings
    match /users/{userId}/earnings/{earningId} {
        allow read, write, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Users can read, write, update and delete their own expenses
    match /users/{userId}/expenses/{expenseId} {
        allow read, write, update, delete: if request.auth != null && request.auth.uid == userId;
    }
  }
}